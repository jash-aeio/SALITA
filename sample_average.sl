/* ============================================ */
/* SALITA Sample - Average of Three Numbers    */
/*                                              */
/* Note: All variables are integers in SALITA, */
/* so division is floor division (truncating).  */
/* ============================================ */

var num1;
var num2;
var num3;
var sum;
var average;

input num1;
input num2;
input num3;

sum = num1 + num2 + num3;
average = sum / 3;

output sum;
output average;
