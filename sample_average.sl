/* ============================================ */
/* SALITA Sample 4 - Average ng Tatlong Numero  */
/* (Average of three numbers)                   */
/*                                              */
/* Dahil integer ang lahat ng variable sa       */
/* SALITA, ang division ay floor division.      */
/* ============================================ */

baryabol num1;
baryabol num2;
baryabol num3;
baryabol sum;
baryabol average;

kuha num1;
kuha num2;
kuha num3;

lagay sum = num1 + num2 + num3;
lagay average = sum / 3;

ipakita sum;
ipakita average;
