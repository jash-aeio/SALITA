/* ============================================ */
/* Halimbawa ng SALITA Program                  */
/* (Sample SALITA Program)                      */
/*                                              */
/* Layunin: Mag-input ng dalawang numero at     */
/* ipakita ang resulta ng (x + y) * 2           */
/* ============================================ */

baryabol x;
baryabol y;
baryabol total;

kuha x;
kuha y;

lagay total = (x + y) * 2;

ipakita total;
